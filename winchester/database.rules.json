{
  "rules": {
    "winchester": {
      ".read": "auth != null",
      ".write": "auth != null",

      "members": {
        ".validate": "newData.hasChildren()",
        "$memberId": {
          ".validate": "newData.hasChildren(['id', 'name', 'avatar'])",
          "id": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "avatar": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "$other": { ".validate": false }
        }
      },

      "log": {
        "$entryId": {
          ".validate": "newData.hasChildren(['memberId', 'drinkId', 'timestamp'])",
          "memberId": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "memberName": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "memberAvatar": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "drinkId": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "drinkName": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "points": { ".validate": "newData.isNumber()" },
          "timestamp": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        }
      },

      "event": {
        ".validate": "newData.hasChildren(['name', 'date'])",
        "name": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "date": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "rsvp": {
          "$memberId": { ".validate": "newData.isString() && (newData.val() === 'yes' || newData.val() === 'no')" }
        },
        "$other": { ".validate": false }
      },

      "checkedIn": {
        "$memberId": {
          ".validate": "newData.val() === true"
        }
      },

      "drinks": {
        ".validate": "newData.hasChildren()",
        "$drinkIndex": {
          ".validate": "newData.hasChildren(['id', 'name', 'points'])",
          "id": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "emoji": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "points": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        }
      },

      "photos": {
        "$photoId": {
          ".validate": "newData.hasChildren(['dataUrl', 'uploadedBy', 'timestamp'])",
          "dataUrl": { ".validate": "newData.isString() && newData.val().length <= 2000000" },
          "uploadedBy": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "uploaderName": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "uploaderAvatar": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "deviceId": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "timestamp": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        }
      },

      "inventory": {
        "$drinkId": {
          ".validate": "newData.hasChildren(['stock', 'unit'])",
          "stock": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99999" },
          "unit": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "$other": { ".validate": false }
        }
      },

      "inventoryResetAt": {
        ".validate": "newData.isNumber()"
      },

      "$other": {
        ".validate": false
      }
    },

    "hospitation": {
      ".read": "auth != null",
      ".write": "auth != null",

      "tours": {
        "$tourId": {
          ".validate": "newData.hasChildren(['type', 'date'])",
          "type": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "category": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "subtype": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "date": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "time": { ".validate": "newData.isString() && newData.val().length <= 10" },
          "guides": {
            "$index": { ".validate": "newData.isString() && newData.val().length <= 100" }
          },
          "trainee1": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "trainee2": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "createdAt": { ".validate": "newData.isNumber()" },
          "source": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "notes": { ".validate": "newData.isString() && newData.val().length <= 1000" },
          "$other": { ".validate": false }
        }
      },

      "trainees": {
        "$name": {
          ".validate": "newData.hasChildren(['name'])",
          "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "active": { ".validate": "newData.isBoolean()" },
          "$other": { ".validate": false }
        }
      },

      "$other": {
        ".validate": false
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
